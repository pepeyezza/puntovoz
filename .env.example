# Base de datos (Supabase Postgres)
# DATABASE_URL: conexión "Transaction pooler" (puerto 6543) — la usa la app en funcionamiento
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:6543/postgres?schema=public"
# DIRECT_URL: conexión "Direct connection" (puerto 5432) — la usan las migraciones de Prisma
DIRECT_URL="postgresql://USUARIO:PASSWORD@HOST:5432/postgres?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generar-con: openssl rand -base64 32"

# Supabase (storage de imágenes)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — SECRETA, nunca la expongas en el navegador. Se usa solo
# en el servidor para subir imágenes a Supabase Storage. La encontrás en
# Project Settings > API > "service_role" (no la "anon").
SUPABASE_SERVICE_ROLE_KEY=""
